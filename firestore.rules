rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is an authenticated admin
    function isAdmin() {
      return request.auth != null;
    }

    // Rules for the 'settings' collection.
    // Only admins can read or write documents in this collection.
    match /settings/{setting} {
      allow read, write: if isAdmin();
    }

    // Rules for the 'events' collection.
    // Anyone can read events, but only admins can create, update, or delete them.
    match /events/{event} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the 'gallery' collection.
    // Anyone can read gallery items, but only admins can manage them.
    match /gallery/{photo} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the 'hero' collection.
    // Anyone can read hero images, but only admins can manage them.
    match /hero/{image} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the 'social-posts' collection.
    // Anyone can read social posts, but only admins can manage them.
    match /social-posts/{post} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
